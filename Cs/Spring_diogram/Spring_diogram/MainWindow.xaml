<Window x:Class="Spring_diogram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Вычислитель физических задач" Height="650" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления файлами -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding InputViewModel.FilePath, UpdateSourceTrigger=PropertyChanged}" Width="500" Margin="0,0,10,0"/>
            <Button Content="Выбрать файл" Width="120" Margin="0,0,10,0" Click="BrowseButton_Click"/>
            <Button Content="Загрузить данные" Width="120" Click="LoadButton_Click"/>
        </StackPanel>

        <!-- Панель управления отменой/повтором -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Undo" Width="100" Margin="0,0,10,0" Click="UndoButton_Click"/>
            <Button Content="Redo" Width="100" Click="RedoButton_Click"/>
            <TextBlock x:Name="StatusTextBlock" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="Green"/>
        </StackPanel>

        <!-- Область входных данных -->
        <GroupBox Grid.Row="2" Header="Входные данные:" Margin="0,0,0,10">
            <TextBlock Text="{Binding InputViewModel.InputDataDescription}" TextWrapping="Wrap" Margin="5" MinHeight="60"/>
        </GroupBox>

        <!-- Область графика -->
        <GroupBox Grid.Row="3" Header="Результат расчета:">
            <oxy:PlotView Model="{Binding SolverViewModel.PlotModel}" />
        </GroupBox>
    </Grid>
</Window>